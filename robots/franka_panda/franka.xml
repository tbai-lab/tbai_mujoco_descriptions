                        <joint name="finger_joint1" class="finger"/>
                        <geom mesh="finger_0" material="off_white" class="visual"/>
                        <geom mesh="finger_1" material="black" class="visual"/>
                        <geom mesh="finger_0" class="collision"/>
                        <geom class="fingertip_pad_collision_1"/>
                        <geom class="fingertip_pad_collision_2"/>
                        <geom class="fingertip_pad_collision_3"/>
                        <geom class="fingertip_pad_collision_4"/>
                        <geom class="fingertip_pad_collision_5"/>
                      </body>
                      <body name="right_finger" pos="0 0 0.0584" quat="0 0 0 1">
                        <inertial mass="0.015" pos="0 0 0" diaginertia="2.375e-6 2.375e-6 7.5e-7"/>
                        <joint name="finger_joint2" class="finger"/>
                        <geom mesh="finger_0" material="off_white" class="visual"/>
                        <geom mesh="finger_1" material="black" class="visual"/>
                        <geom mesh="finger_0" class="collision"/>
                        <geom class="fingertip_pad_collision_1"/>
                        <geom class="fingertip_pad_collision_2"/>
                        <geom class="fingertip_pad_collision_3"/>
                        <geom class="fingertip_pad_collision_4"/>
                        <geom class="fingertip_pad_collision_5"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Torque-mode actuators for unitree_sdk2 bridge compatibility -->
  <actuator>
    <motor class="franka" name="joint1_motor" joint="joint1" ctrlrange="-87 87"/>
    <motor class="franka" name="joint2_motor" joint="joint2" ctrlrange="-87 87"/>
    <motor class="franka" name="joint3_motor" joint="joint3" ctrlrange="-87 87"/>
    <motor class="franka" name="joint4_motor" joint="joint4" ctrlrange="-87 87"/>
    <motor class="franka" name="joint5_motor" joint="joint5" ctrlrange="-12 12"/>
    <motor class="franka" name="joint6_motor" joint="joint6" ctrlrange="-12 12"/>
    <motor class="franka" name="joint7_motor" joint="joint7" ctrlrange="-12 12"/>
    <motor class="finger" name="finger1_motor" joint="finger_joint1"/>
    <motor class="finger" name="finger2_motor" joint="finger_joint2"/>
  </actuator>

  <!-- Sensors in unitree_sdk2 convention: pos, vel, torque for each motor, then IMU, then frame -->
  <sensor>
    <!-- Joint position sensors (one per actuator, same order as actuators) -->
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointpos name="joint4_pos" joint="joint4"/>
    <jointpos name="joint5_pos" joint="joint5"/>
    <jointpos name="joint6_pos" joint="joint6"/>
    <jointpos name="joint7_pos" joint="joint7"/>
    <jointpos name="finger1_pos" joint="finger_joint1"/>
    <jointpos name="finger2_pos" joint="finger_joint2"/>

    <!-- Joint velocity sensors -->
    <jointvel name="joint1_vel" joint="joint1"/>
    <jointvel name="joint2_vel" joint="joint2"/>
    <jointvel name="joint3_vel" joint="joint3"/>
    <jointvel name="joint4_vel" joint="joint4"/>
    <jointvel name="joint5_vel" joint="joint5"/>
    <jointvel name="joint6_vel" joint="joint6"/>
    <jointvel name="joint7_vel" joint="joint7"/>
    <jointvel name="finger1_vel" joint="finger_joint1"/>
    <jointvel name="finger2_vel" joint="finger_joint2"/>

    <!-- Joint torque sensors -->
    <jointactuatorfrc name="joint1_torque" joint="joint1" noise="0.01"/>
    <jointactuatorfrc name="joint2_torque" joint="joint2" noise="0.01"/>
    <jointactuatorfrc name="joint3_torque" joint="joint3" noise="0.01"/>
    <jointactuatorfrc name="joint4_torque" joint="joint4" noise="0.01"/>
    <jointactuatorfrc name="joint5_torque" joint="joint5" noise="0.01"/>
    <jointactuatorfrc name="joint6_torque" joint="joint6" noise="0.01"/>
    <jointactuatorfrc name="joint7_torque" joint="joint7" noise="0.01"/>
    <jointactuatorfrc name="finger1_torque" joint="finger_joint1" noise="0.01"/>
    <jointactuatorfrc name="finger2_torque" joint="finger_joint2" noise="0.01"/>

    <!-- IMU sensors -->
    <framequat name="imu_quat" objtype="site" objname="imu"/>
    <gyro name="imu_gyro" site="imu"/>
    <accelerometer name="imu_acc" site="imu"/>

    <!-- Frame position/velocity for high-level state -->
    <framepos name="frame_pos" objtype="site" objname="imu"/>
    <framelinvel name="frame_vel" objtype="site" objname="imu"/>
  </sensor>

  <keyframe>
    <key name="stand" qpos="0 0 0 -1.57079 0 1.57079 -0.7853 0.04 0.04"
         ctrl="0 0 0 0 0 0 0 0 0"/>
    <key name="sit" qpos="0 -0.5 0 -2.8 0 2.0 0 0.04 0.04"
         ctrl="0 0 0 0 0 0 0 0 0"/>
  </keyframe>

  <contact>
    <exclude body1="base_link" body2="link1"/>
  </contact>
</mujoco>
