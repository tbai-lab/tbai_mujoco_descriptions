<mujoco model="spot">
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <option cone="elliptic" impratio="100" />

  <default>
    <default class="spot">
      <geom friction="0.4" margin="0.001" condim="1"/>
      <joint axis="0 1 0" damping="0.1" armature="0.01" frictionloss="0.2"/>
      <motor ctrlrange="-80 80"/>
      <default class="abduction">
        <joint axis="1 0 0" range="-0.785398 0.785398"/>
      </default>
      <default class="hip">
        <joint range="-0.898845 2.29511"/>
      </default>
      <default class="knee">
        <joint range="-2.7929 -0.2474"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom group="3" type="mesh"/>
        <default class="foot">
          <geom type="sphere" size="0.036" pos="0 0 -0.3365" priority="1" condim="6"
            friction="0.4 0.02 0.01"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <material name="BlackAbs" rgba="0.1 0.1 0.1 1"/>
    <material name="wrap" rgba="0.878431 0.666666 0.227450 1"/>

    <mesh file="body_0.obj"/>
