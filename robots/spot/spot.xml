  <contact>
    <exclude body1="base_link" body2="FL_thigh"/>
    <exclude body1="base_link" body2="FR_thigh"/>
    <exclude body1="base_link" body2="RL_thigh"/>
    <exclude body1="base_link" body2="RR_thigh"/>
  </contact>

  <actuator>
